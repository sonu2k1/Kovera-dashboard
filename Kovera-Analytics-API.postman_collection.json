{
  "info": {
    "name": "Kovera Analytics API",
    "description": "Platform-wide admin analytics endpoints for Kovera-App.\n\nAll endpoints are under `/api/analytics/`.\n\nTime-series endpoints accept optional query params:\n- `from` (ISO 8601) — defaults to 30 days ago\n- `to` (ISO 8601) — defaults to now\n- `granularity` — `day` | `week` | `month` (default: `day`)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/analytics/dashboard?from=2025-01-01T00:00:00Z&to=2026-04-17T00:00:00Z",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "dashboard"],
              "query": [
                { "key": "from", "value": "2025-01-01T00:00:00Z" },
                { "key": "to", "value": "2026-04-17T00:00:00Z" }
              ]
            },
            "description": "Top-level KPIs with period-over-period comparison. Defaults to last 30 days if no params provided."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"totalUsers\": 1243,\n  \"totalAgents\": 87,\n  \"totalListings\": 312,\n  \"totalChains\": 45,\n  \"totalReferrals\": 198,\n  \"activeListings\": 278,\n  \"completedOnboarding\": 934,\n  \"periodComparison\": {\n    \"newUsers\": { \"current\": 142, \"previous\": 118, \"changePct\": 20.34 },\n    \"newAgents\": { \"current\": 12, \"previous\": 9, \"changePct\": 33.33 },\n    \"newChains\": { \"current\": 8, \"previous\": 5, \"changePct\": 60 },\n    \"newReferrals\": { \"current\": 34, \"previous\": 28, \"changePct\": 21.43 },\n    \"impressions\": { \"current\": 8920, \"previous\": 7105, \"changePct\": 25.54 }\n  }\n}"
            }
          ]
        }
      ]
    },
